                            <classpathPrefix>lib1/</classpathPrefix>
                            <mainClass>com.yiban.javaBase.dev.syntax.EnumDemo</mainClass>
                        </manifest>
                    </archive>
                </configuration>
            </plugin>

            <!-- 拷贝依赖的jar包到lib目录 -->
